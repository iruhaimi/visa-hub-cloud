# ============================================================
# Supabase Configuration
# Copy this file to .env and fill in your new project values
# ============================================================

# Your Supabase project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL="https://YOUR_NEW_PROJECT_REF.supabase.co"

# Your Supabase anon/public key
# Found in: Supabase Dashboard → Project Settings → API → anon (public)
VITE_SUPABASE_PUBLISHABLE_KEY="your_new_anon_key"

# Your Supabase project reference ID (the part before .supabase.co)
VITE_SUPABASE_PROJECT_ID="YOUR_NEW_PROJECT_REF"
